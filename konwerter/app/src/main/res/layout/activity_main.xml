<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F0F2F5">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Konwerter Liczb"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:textColor="#1A237E"/>

    <EditText
        android:id="@+id/etInput"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="Wpisz liczbę"
        android:focusable="true"
        android:clickable="true"
        android:textSize="24sp"
        android:gravity="center"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:inputType="none"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvOutput"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Wynik"
        android:textSize="24sp"
        android:gravity="center"
        android:background="#E3F2FD"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:textColor="#0D47A1"
        android:textStyle="bold"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <GridLayout
            android:id="@+id/keyboardArabic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="4"
            android:visibility="visible">

            <Button android:text="1" style="@style/CalcButton" />
            <Button android:text="2" style="@style/CalcButton" />
            <Button android:text="3" style="@style/CalcButton" />
            <Button android:text="4" style="@style/CalcButton" />
            <Button android:text="5" style="@style/CalcButton" />
            <Button android:text="6" style="@style/CalcButton" />
            <Button android:text="7" style="@style/CalcButton" />
            <Button android:text="8" style="@style/CalcButton" />
            <Button android:text="9" style="@style/CalcButton" />
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" />
            <Button android:text="0" style="@style/CalcButton" />
            <Button android:id="@+id/btnBackArabic" android:text="DEL" style="@style/CalcButton" android:textColor="#B71C1C" />
        </GridLayout>

        <GridLayout
            android:id="@+id/keyboardRoman"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="3"
            android:visibility="gone">

            <Button android:text="I" style="@style/CalcButton" />
            <Button android:text="V" style="@style/CalcButton" />
            <Button android:text="X" style="@style/CalcButton" />
            <Button android:text="L" style="@style/CalcButton" />
            <Button android:text="C" style="@style/CalcButton" />
            <Button android:text="D" style="@style/CalcButton" />
            <Button android:text="M" style="@style/CalcButton" />
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" />
            <Button android:id="@+id/btnBackRoman" android:text="DEL" style="@style/CalcButton" android:textColor="#B71C1C" />
        </GridLayout>
    </FrameLayout>

    <Button
        android:id="@+id/btnSwitchMode"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Zmień tryb"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:backgroundTint="#1A237E"
        android:textColor="@android:color/white"/>

</LinearLayout>
